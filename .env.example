# ============================================================
# .env.example — Projeto_Contas_Orcamento
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env em repositórios públicos!
# ============================================================

# --- Segurança Flask ---
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque_por_uma_chave_secreta_longa_e_aleatoria

# --- Banco de Dados PostgreSQL ---
DATABASE_URL=postgresql://postgres:SUA_SENHA_AQUI@localhost:5432/ContasOrcamento
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=SUA_SENHA_AQUI
DB_NAME=ContasOrcamento

# --- E-mail (para alertas de vencimento) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_de_app_gmail
EMAIL_RECEIVER=destino@gmail.com
